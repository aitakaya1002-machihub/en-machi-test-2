---
import Breadcrumbs from '@/components/Breadcrumbs';
import ContentFilter from '@/components/ContentFilter';
import PageHeader from '@/components/PageHeader';
import StoryCard from '@/components/StoryCard';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getAllStories } from '../../lib/content';

const stories = await getAllStories();
const categories = Array.from(new Set(stories.map((story) => story.frontmatter.category)));
---

<SiteLayout
  title="ローカルストーリー"
  description="円町の人・店・場所の背景にある物語を紹介する一覧ページです。"
  currentPath="/stories"
>
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <Breadcrumbs items={[{ label: 'ストーリー' }]} />
    <PageHeader
      title="ローカルストーリー"
      description="円町の人・店・場所の背景にある物語を紹介します。"
    />
    <ContentFilter client:load scopeId="stories-filter-scope" categories={categories} />
    <div id="stories-filter-scope">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {stories.map((item) => (
          <div data-filter-item data-filter-values={item.frontmatter.category}>
            <StoryCard story={item.frontmatter} />
          </div>
        ))}
      </div>
      <div data-filter-empty hidden class="mt-8 rounded-sm border border-dashed border-gray-200 bg-gray-50 px-5 py-8 text-sm text-gray-500">
        該当するストーリーはありません。
      </div>
    </div>
  </div>
</SiteLayout>
