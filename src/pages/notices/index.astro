---
import Breadcrumbs from '@/components/Breadcrumbs';
import Link from '@/components/Link';
import PageHeader from '@/components/PageHeader';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getAllNotices } from '../../lib/content';

const notices = await getAllNotices();
---

<SiteLayout
  title="お知らせ"
  description="en-machiからのお知らせ一覧です。掲載情報や運営からの案内を確認できます。"
  currentPath="/notices"
>
  <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <Breadcrumbs items={[{ label: 'お知らせ' }]} />
    <PageHeader title="お知らせ" />
    <div class="space-y-4">
      {notices.map((item) => (
        <Link
          href={`/notices/${item.frontmatter.slug}`}
          className="block p-4 border border-gray-100 rounded-sm hover:bg-gray-50 transition-colors"
        >
          <div class="flex items-center gap-3 text-xs text-gray-500 mb-1">
            <span>{item.frontmatter.date}</span>
            <span class="px-2 py-0.5 bg-gray-100 rounded-full">{item.frontmatter.category}</span>
          </div>
          <h3 class="text-sm font-medium">{item.frontmatter.title}</h3>
        </Link>
      ))}
    </div>
  </div>
</SiteLayout>
